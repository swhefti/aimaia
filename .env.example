# ============================================================
# Portfolio Advisor — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Supabase — https://supabase.com/dashboard/project/<project>/settings/api
# ------------------------------------------------------------

# Your Supabase project URL (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key for browser-side Supabase access
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — NEVER expose to browser, server-side only
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# Anthropic — https://console.anthropic.com/settings/keys
# ------------------------------------------------------------

# Anthropic API key for the LLM Synthesis Agent
ANTHROPIC_API_KEY=

# ------------------------------------------------------------
# Market Data Providers
# ------------------------------------------------------------

# Twelve Data — OHLCV price history: https://twelvedata.com/account/api-keys
TWELVE_DATA_API_KEY=

# Finnhub — News and fundamentals: https://finnhub.io/dashboard
FINNHUB_API_KEY=

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Public URL of the deployed app (used for OAuth redirects, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Runtime environment: development | staging | production
NODE_ENV=development
